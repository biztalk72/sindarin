{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /:*)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(terraform destroy:*)",
      "Bash(aws iam:*)",
      "Bash(kubectl delete:*)"
    ]
  },
  "sandbox": {
    "failIfUnavailable": false,
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "secrets/**",
        "**/credentials/**",
        "**/*.pem",
        "**/*.key"
      ],
      "allowRead": [
        ".env.example"
      ]
    }
  }
}
