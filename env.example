# Hybrid IDP — environment template. Copy to .env (gitignored) and fill in real values.
# Refs: ADR-0001 (models), ADR-0005 (auth), ADR-0008 (vector db), PRD2 §10.1 (security).
#
# IMPORTANT: this file is consumed by Docker Compose `env_file`, which does NOT support
# inline comments. Keep comments on their own lines — never after `KEY=value`, or the
# comment becomes part of the value.

# --- App ---
APP_ENV=local
APP_LOG_LEVEL=info
# ko | en (bilingual first-class, invariant #5)
APP_DEFAULT_LOCALE=ko

# --- Host port mappings (override to avoid local conflicts) ---
WEB_PORT=3000
API_PORT=8000

# --- Auth (ADR-0005) ---
# Must be >= 32 bytes in prod. Generate with: openssl rand -hex 32
IDP_JWT_SECRET=dev-only-change-me-please-至少-32-bytes-長い-시크릿
IDP_JWT_ALG=HS256
IDP_TOKEN_TTL_MINUTES=720
IDP_OIDC_ENABLED=false
# IDP_OIDC_ISSUER=
# IDP_OIDC_CLIENT_ID=
# Bootstrap admin — created on startup if set (single-org). Change the password.
IDP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
IDP_BOOTSTRAP_ADMIN_PASSWORD=changeme-admin-pw

# --- Postgres ---
# POSTGRES_HOST/PORT = in-container address the API connects to (compose network).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# POSTGRES_PUBLISHED_PORT = host port for migrations/tools (override to avoid clashes).
POSTGRES_PUBLISHED_PORT=5432
POSTGRES_DB=hybrid_idp
POSTGRES_USER=hybrid_idp
POSTGRES_PASSWORD=replace-me

# --- Object store (MinIO / S3-compatible) ---
OBJECT_STORE_ENDPOINT=http://object-store:9000
OBJECT_STORE_BUCKET=hybrid-idp
OBJECT_STORE_ACCESS_KEY=replace-me
OBJECT_STORE_SECRET_KEY=replace-me

# --- Vector DB (ADR-0008; backend chosen after P0 benchmark, PRD2 §15) ---
# qdrant | pgvector
VECTOR_DB_KIND=qdrant
VECTOR_DB_URL=http://vector-db:6333
# Serving collection/alias (blue/green via embedding_worker).
VECTOR_COLLECTION=documents

# --- Models (ADR-0001: OpenAI-compatible, per-model base_url) ---
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=http://localhost:8080/v1
# Chat/generation model (model router v1).
ANSWER_MODEL=default-answer
# Set EMBEDDING_MODEL to enable /api/chat (follow-up ADR: PRD2 §15). Leave blank to keep
# the endpoint gated off.
EMBEDDING_MODEL=
# Falls back to OPENAI_BASE_URL if empty.
EMBEDDING_BASE_URL=
# Vector size for the Qdrant collection.
EMBEDDING_DIM=1536

# --- Self-hosted LLM stack (infra/compose/llm.yml; vLLM on the GB10) ---
# Start: docker compose --env-file .env -f infra/compose/dev.yml -f infra/compose/llm.yml up -d
# Then set the model vars above to the in-network services (docs/runbooks/go-live.md):
#   OPENAI_BASE_URL=http://vllm-chat:8000/v1   ANSWER_MODEL=qwen2.5-14b
#   EMBEDDING_BASE_URL=http://vllm-embed:8000/v1   EMBEDDING_MODEL=bge-m3   EMBEDDING_DIM=1024
CHAT_MODEL=Qwen/Qwen2.5-14B-Instruct
EMBED_MODEL=BAAI/bge-m3
VLLM_CHAT_PORT=8001
VLLM_EMBED_PORT=8082
VLLM_MAX_LEN=8192

# --- GB10 worker resource policy (ADR-0010, PRD2 §3) ---
WORKER_CONCURRENCY=2
WORKER_MEMORY_LIMIT_MB=8192
