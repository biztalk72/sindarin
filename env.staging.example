# Staging environment template → copy to .env.staging (gitignored). Comments on own lines
# (compose env_file does not support inline comments — see compose-env footgun).

# --- Image rollout (set by CI/CD) ---
REGISTRY=registry.example.com/hybrid-idp
IMAGE_TAG=staging

# --- App ---
APP_ENV=staging
APP_LOG_LEVEL=info
APP_DEFAULT_LOCALE=ko
WEB_PORT=3000
API_PORT=8000

# --- Auth (ADR-0005) — generate: openssl rand -hex 32 ---
IDP_JWT_SECRET=staging-change-me-至少-32-bytes-시크릿-please
IDP_JWT_ALG=HS256
IDP_TOKEN_TTL_MINUTES=720
IDP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
IDP_BOOTSTRAP_ADMIN_PASSWORD=staging-admin-pw

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_PUBLISHED_PORT=5432
POSTGRES_DB=hybrid_idp
POSTGRES_USER=hybrid_idp
POSTGRES_PASSWORD=staging-change-me

# --- Object store / Vector DB ---
OBJECT_STORE_ENDPOINT=http://object-store:9000
OBJECT_STORE_BUCKET=hybrid-idp
OBJECT_STORE_ACCESS_KEY=staging-change-me
OBJECT_STORE_SECRET_KEY=staging-change-me
VECTOR_DB_KIND=qdrant
VECTOR_DB_URL=http://vector-db:6333
VECTOR_COLLECTION=documents

# --- Models (ADR-0001) — leave EMBEDDING_MODEL blank for dev-mode answers ---
OPENAI_API_KEY=staging-change-me
OPENAI_BASE_URL=http://llm:8080/v1
ANSWER_MODEL=default-answer
EMBEDDING_MODEL=
EMBEDDING_DIM=1536
