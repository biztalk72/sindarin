# Production environment template → copy to .env.prod (gitignored) and fill from your secret
# store. Comments on own lines (compose env_file has no inline comments).
# Postgres is NOT published to the host in prod (internal only).

# --- Image rollout (set by CI/CD) ---
REGISTRY=registry.example.com/hybrid-idp
IMAGE_TAG=latest

# --- App ---
APP_ENV=prod
APP_LOG_LEVEL=info
APP_DEFAULT_LOCALE=ko
WEB_PORT=3000
API_PORT=8000

# --- Auth (ADR-0005) — MUST be >= 32 bytes; from secret store. openssl rand -hex 32 ---
IDP_JWT_SECRET=__SET_FROM_SECRET_STORE__
IDP_JWT_ALG=HS256
IDP_TOKEN_TTL_MINUTES=720
IDP_BOOTSTRAP_ADMIN_EMAIL=admin@yourorg.example
IDP_BOOTSTRAP_ADMIN_PASSWORD=__SET_FROM_SECRET_STORE__

# --- Postgres (required: no defaults in prod compose) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hybrid_idp
POSTGRES_USER=hybrid_idp
POSTGRES_PASSWORD=__SET_FROM_SECRET_STORE__

# --- Object store / Vector DB ---
OBJECT_STORE_ENDPOINT=http://object-store:9000
OBJECT_STORE_BUCKET=hybrid-idp
OBJECT_STORE_ACCESS_KEY=__SET_FROM_SECRET_STORE__
OBJECT_STORE_SECRET_KEY=__SET_FROM_SECRET_STORE__
VECTOR_DB_KIND=qdrant
VECTOR_DB_URL=http://vector-db:6333
VECTOR_COLLECTION=documents

# --- Models (ADR-0001) ---
OPENAI_API_KEY=__SET_FROM_SECRET_STORE__
OPENAI_BASE_URL=http://llm:8080/v1
ANSWER_MODEL=default-answer
EMBEDDING_MODEL=
EMBEDDING_DIM=1536
